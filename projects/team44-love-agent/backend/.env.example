# Copy this file to backend/.env for local development.
# Do not commit backend/.env.

UPSTAGE_API_KEY=up_xxx_replace_with_your_key
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_MODEL=solar-pro3

# mock keeps local API/SSE/workflow validation independent from external LLM calls.
# Set to "upstage" with a real UPSTAGE_API_KEY when ready to call Solar.
LLM_PROVIDER=mock

# Comma-separated browser origins allowed to call the API during local testing.
CORS_ALLOW_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

