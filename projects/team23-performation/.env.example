# Backend
PERFORMATION_API_HOST=127.0.0.1
PERFORMATION_API_PORT=8000

# Docker Compose host ports
PERFORMATION_BACKEND_PORT=8000
PERFORMATION_FRONTEND_PORT=7860
# Optional: override the frontend container's backend URL.
# PERFORMATION_FRONTEND_API_URL=http://backend:8000

# CORS — 쉼표로 여러 출처 지정 가능. 기본값 * (개발용)
# PERFORMATION_CORS_ORIGINS=http://localhost:7860,http://127.0.0.1:7860

# 에이전트 실행 타임아웃 (초). 기본값 30
# PERFORMATION_AGENT_TIMEOUT_SECONDS=30

# 로그 레벨. DEBUG / INFO / WARNING / ERROR. 기본값 INFO
# PERFORMATION_LOG_LEVEL=INFO

# Frontend
PERFORMATION_API_URL=http://127.0.0.1:8000

# Search provider keys are optional for the scaffold.
# PERFORMATION_SEARCH_PROVIDER=tavily
# PERFORMATION_SEARCH_TIMEOUT_SECONDS=10
# PERFORMATION_SEARCH_MAX_RESULTS=3
# TAVILY_API_KEY=
# BRAVE_SEARCH_API_KEY=

# KOPIS official performance data is optional. Without a key the agent skips it.
# PERFORMATION_KOPIS_TIMEOUT_SECONDS=10
# PERFORMATION_KOPIS_LOOKAHEAD_DAYS=120
# PERFORMATION_KOPIS_ROWS=10
# KOPIS_API_KEY=

# Gemini LLM generation is optional; without a key the agent uses deterministic fallback.
# PERFORMATION_LLM_PROVIDER=gemini
# PERFORMATION_LLM_MODEL=gemini-2.5-flash-lite
# PERFORMATION_LLM_TIMEOUT_SECONDS=20
# GEMINI_API_KEY=
