# Next.js rewrite와 서버 요청에서 사용하는 백엔드 API base URL입니다.
# 로컬 백엔드 기본 포트는 8000입니다.
API_BASE_URL=http://localhost:8000

# 공개 앱 base URL입니다. 코드의 기본값은 http://localhost:3000입니다.
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# 백엔드 API를 호출하지 않고 로컬 목 응답을 사용합니다.
# 백엔드 없이 프론트엔드를 개발할 때만 true로 설정하세요.
NEXT_PUBLIC_USE_MOCK=false
