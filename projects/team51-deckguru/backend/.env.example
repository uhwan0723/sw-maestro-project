# Upstage Solar (Strategy Agent LLM)
UPSTAGE_API_KEY=

# 모델 분리 (recommend/meta는 강력, intent는 cheap)
UPSTAGE_MODEL_RECOMMEND=solar-pro2
UPSTAGE_MODEL_META=solar-pro2
UPSTAGE_MODEL_INTENT=solar-mini

# 현재 패치
PATCH_VERSION=17.2

# ChromaDB 경로 (Agent-2 빌드 결과물)
CHROMA_PATH=../data/rag/vectorstore/chroma

# BGE-M3 모델명 또는 로컬 모델 디렉토리
EMBEDDING_MODEL=/Users/dongwoo/Projects/deckguru/models/bge-m3

# RAG 검색 최소 유사도 점수
RAG_MIN_SCORE=0.05

# Live Research 강제 비활성화 (Agent-3 미완성 시 폴백)
LIVE_RESEARCH_ENABLED=true
LIVE_RESEARCH_TIMEOUT_S=12
LIVE_RESEARCH_MAX_STEPS=2
RESEARCH_LLM_PLANNER_ENABLED=false
RESEARCH_LLM_EXTRACT_ENABLED=false

# 전체 추천 요청 timeout. Live Research 사용 시 frontend timeout보다 짧아야 함
AGENT_TIMEOUT_S=40

# 데모 모드 — rate limit 완화 + debug 필드 노출
DEMO_MODE=false

# 명시적으로 true일 때만 Strategy mock fixture 사용
MOCK_STRATEGY_AGENT=false

# 관리자 토큰 (/api/_internal/cache-stats)
ADMIN_TOKEN=dev-admin

# 로그 레벨
LOG_LEVEL=INFO
APP_LOG_FORMAT=console
APP_LOG_COLORS=true

# Tavily (Live Research, Agent-3 연동 후 필요)
TAVILY_API_KEY=
